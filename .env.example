# Password for the Flask web UI login page
APP_PASSWORD=your_secret_password

# Hostname or IP address of the MySQL server
DB_HOST=localhost

# Port on which MySQL is listening
DB_PORT=3306

# Name of the MySQL database to use
DB_NAME=product_checker

# MySQL username
DB_USER=root

# MySQL password for the above user
DB_PASSWORD=your_db_password

# Base URL of the FastAPI backend — must match the port uvicorn is started on
FASTAPI_BASE_URL=http://localhost:8100
